# =============================================================================
# NovaPower — Dynamic Yield demo — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# =============================================================================

# -----------------------------------------------------------------------------
# CLIENT-SIDE (exposed to the browser) — must be VITE_-prefixed under Vite.
# -----------------------------------------------------------------------------

# DY Section ID the native loader scripts (api_dynamic.js + api_static.js) target.
# This is the ONE value an SE changes to point the entire demo at a different DY
# account/section. No code changes or component edits required.
VITE_DY_SECTION_ID=8795021

# (Optional) Override the slot DIV ids that DY campaigns target. Defaults shown.
# Use these only if a prospect's DY account already standardises on other ids.
# VITE_DY_SLOT_HOMEPAGE_HERO=dy-slot-homepage-hero
# VITE_DY_SLOT_HOMEPAGE_RECS=dy-slot-homepage-recs
# VITE_DY_SLOT_HOMEPAGE_TRENDING=dy-slot-homepage-trending
# VITE_DY_SLOT_CATEGORY_RECS=dy-slot-category-recs
# VITE_DY_SLOT_PDP_RECS=dy-slot-pdp-recs
# VITE_DY_SLOT_CART_RECS=dy-slot-cart-recs
# VITE_DY_SLOT_ACCOUNT_RECS=dy-slot-account-recs

# -----------------------------------------------------------------------------
# SERVER-SIDE (never exposed to the browser) — used by the remaining /api proxies
# for DY features that legitimately require a server-side key (Shopping Muse,
# Visual Search). These are unrelated to the recommendations/choose flow, which
# is now 100% client-side.
# -----------------------------------------------------------------------------

# Shopping Muse / Agent Assistant proxy (api/shopping-muse.ts)
SHOPPINGMUSE_API_KEY=

# Visual Search proxy (api/visual-search.ts)
VISUALSEARCH_API_KEY=

# (Optional) Disable Vite HMR to make the dev server behave like a static build
# DISABLE_HMR=true
